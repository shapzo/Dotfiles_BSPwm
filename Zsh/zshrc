# Change to shell: chsh user -s /bin/zsh
# Exit if it is not an interactive shell
[[ $- == *i* ]] || return

# Load modules
ZCONF="$HOME/.config/zsh"
# Theme
source "$ZCONF/themes/pacman.zsh"

for module in \
    "$ZCONF/1-exports.zsh" \
    "$ZCONF/2-init.zsh" \
    "$ZCONF/3-history.zsh" \
    "$ZCONF/4-plugins.zsh" \
    "$ZCONF/5-fzf.zsh" \
    "$ZCONF/6-zoxide.zsh" \
    "$ZCONF/7-keybindings.zsh" \
    "$ZCONF/8-alias.zsh" \
    "$ZCONF/9-functions.zsh"; do
    [[ -f "$module" ]] && source "$module" || echo "Fail: $module"
done

alias reload='source ~/.zshrc