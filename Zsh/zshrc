# FZF-Tab Package Completion (Pacman/Paru) usig expac
zstyle ':fzf-tab:complete:(pacman|paru):*' fzf-preview '
    pkg=$word

    {
        if expac -S "%n" "$pkg" &>/dev/null; then
            # Official Repositories (Fast Preview)
            expac -H M -S "­¤ō” Name           : %n
­¤ōé Repository     : %r
­¤ö¢ Version        : %v
­¤ÅŚ’ĖÅ Architecture    : %a
­¤ōØ Description    : %d
­¤īÉ URL            : %u
ŌÜ¢’ĖÅ Licenses       : %L
­¤ÆŠ Installed Size : %m
­¤ōģ Build Date     : %b
­¤æż Packager       : %p
­¤öŚ Depends On     : %D
Ō×Ģ Optional Deps  : %O
ŌÜĀ’ĖÅ Conflicts      : %C
­¤öä Replaces       : %e" "$pkg"
        else
            # AUR Fallback (Paru)
            paru -Si "$pkg" 2>/dev/null | sed \
                -e "s/^Name/­¤ō” Name/" \
                -e "s/^Version/­¤ö¢ Version/" \
                -e "s/^Description/­¤ōØ Description/" \
                -e "s/^Architecture/­¤ÅŚ’ĖÅ Architecture/" \
                -e "s/^URL/­¤īÉ URL/" \
                -e "s/^Licenses/ŌÜ¢’ĖÅ Licenses/" \
                -e "s/^Installed Size/­¤ÆŠ Installed Size/" \
                -e "s/^SHA256 Sum/­¤øĪ’ĖÅ SHA Validation/" \
                -e "s/^Depends On/­¤öŚ Depends On/" \
                -e "s/^Make Deps/­¤øĀ’ĖÅ Make Deps/" \
                -e "s/^Check Deps/­¤¦¬ Check Deps/" \
                -e "s/^Optional Deps/Ō×Ģ Optional Deps/" \
                -e "s/^Conflicts With/ŌÜĀ’ĖÅ Conflicts/" \
                -e "s/^Maintainer/­¤æż Maintainer/" \
                -e "s/^Votes/­¤Ś│’ĖÅ Votes/" \
                -e "s/^Popularity/­¤ōł Popularity/" \
                -e "s/^Last Modified/­¤ōģ Last Modified/"
        fi

        echo
        echo -e "\e[1;35m­¤ōé PACKAGE FILES:\e[0m"
        { pacman -Fl "$pkg" 2>/dev/null || paru -Fl "$pkg" 2>/dev/null; } | awk "NF>1{print \$2}"
    } | bat -l yaml -p --color=always'

