  case $realpath in
    *.tar*|*.tgz) tar -tvf "$realpath" ;;
    *.zip) unzip -l "$realpath" ;;
    *.rar) unrar l "$realpath" ;;
    *.docx|*.odt) pandoc "$realpath" ;;
