    *)

    if [[ -d $realpath ]]; then
        eza -1 --icons --group-directories-first --color=always -hl --smart-group --no-filesize "$realpath"
    else
        bat --color=always --line-range :500 "$realpath" 2>/dev/null || cat "$realpath"
    fi ;;
  esac'

